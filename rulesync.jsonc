{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": [
    "copilot",
    "claudecode",
    "codexcli",
    "geminicli",
    "opencode",
    "antigravity",
    "factorydroid"
  ],
  "features": [
    "rules",
    "ignore",
    "mcp",
    "commands",
    "subagents",
    "skills",
    "hooks"
  ],
  "baseDirs": [
    "."
  ],
  "delete": false,
  "verbose": true,
  "silent": false,
  "global": true,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false
}
